<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Pulse" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/surface2</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:textColor">@color/text</item>
    </style>
    <style name="Theme.Pulse.Splash" parent="Theme.Pulse">
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="InputStyle">
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textColorHint">@color/text2</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="BtnPrimary">
        <item name="android:background">@drawable/btn_primary_bg</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">14dp</item>
    </style>
    <style name="BtnSecondary">
        <item name="android:background">@drawable/btn_secondary_bg</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">15sp</item>
        <item name="android:padding">14dp</item>
    </style>
</resources>
